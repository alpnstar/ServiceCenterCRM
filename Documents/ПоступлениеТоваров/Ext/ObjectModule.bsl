
Процедура ОбработкаПроведения(Отказ, Режим)
	//{{__КОНСТРУКТОР_ДВИЖЕНИЙ_РЕГИСТРОВ
	// Данный фрагмент построен конструктором.
	// При повторном использовании конструктора, внесенные вручную изменения будут утеряны!!!

	// регистр ОстаткиНоменклатуры Приход
	Движения.ОстаткиТоваров.Записывать = Истина;
	Для Каждого ТекСтрокаТовары Из Товары Цикл
		Движение = Движения.ОстаткиТоваров.Добавить();
		Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
		Движение.Период = Дата;
		Движение.Номенклатура = ТекСтрокаТовары.Номенклатура;
		Движение.Склад = Склад;
		Движение.Серия = ТекСтрокаТовары.Серия;
		Движение.Количество = ТекСтрокаТовары.Количество;
	КонецЦикла;

	// регистр ЦеныПоставщиков
	Движения.ЦеныПоставщиков.Записывать = Истина;
	Для Каждого ТекСтрокаТовары Из Товары Цикл
		Движение = Движения.ЦеныПоставщиков.Добавить();
		Движение.Период = Дата;
		Движение.Номенклатура = ТекСтрокаТовары.Номенклатура;
		Движение.Поставщик = Поставщик;
		Движение.Цена = ТекСтрокаТовары.Цена;
	КонецЦикла;

	//}}__КОНСТРУКТОР_ДВИЖЕНИЙ_РЕГИСТРОВ
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	СуммаДокумента = Товары.Итог("Сумма");
	
	Для Каждого Строка Из Товары Цикл
		Если НЕ ЗначениеЗаполнено(Строка.Серия) И ЗначениеЗаполнено(Строка.Номенклатура) Тогда
			Строка.Серия = СоздатьСерию(Строка.Номенклатура, Ссылка);
		КонецЕсли; 
	КонецЦикла; 
КонецПроцедуры

Функция СоздатьСерию(Номенклатура, ДокументСсылка)
	Серия = Справочники.СерииНоменклатуры.СоздатьЭлемент();
	Серия.Номенклатура = Номенклатура;
	Серия.ДокументПоступления = ДокументСсылка;
	 Серия.Наименование = 
        Номенклатура.Наименование 
        + " " 
        + Формат(ТекущаяДата(), "ДФ=yyyyMMddHHmmss");
	   
	    Серия.Записать();
    Возврат Серия.Ссылка;
КонецФункции 
