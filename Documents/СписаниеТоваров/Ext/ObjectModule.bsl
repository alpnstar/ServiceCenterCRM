
Процедура ОбработкаПроведения(Отказ, Режим)
	
	// 1. Устанавливаем управляемую блокировку данных
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.ОстаткиТоваров");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	
	// Говорим платформе перебрать строки из нашей табличной части "Товары"
	ЭлементБлокировки.ИсточникДанных = Товары;
	
	// Склад берем из ШАПКИ документа (устанавливаем жестко одно значение)
	ЭлементБлокировки.УстановитьЗначение("Склад", Склад);
	
	// Номенклатуру и Серию берем из КОЛОНОК табличной части (передаем имена колонок строками)
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Номенклатура", "Номенклатура");
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Серия", "Серия");
	
	Блокировка.Заблокировать();
	
	// 2. Формируем движения (пока только по количеству)
	Движения.ОстаткиТоваров.Записывать = Истина;
	Для Каждого ТекСтрока Из Товары Цикл
		Движение = Движения.ОстаткиТоваров.Добавить();
		Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
		Движение.Период = Дата;
		Движение.Склад = Склад; 
		Движение.Номенклатура = ТекСтрока.Номенклатура;
		Движение.Серия = ТекСтрока.Серия;
		Движение.Количество = ТекСтрока.Количество;
		// Сумму (себестоимость) пока не заполняем
	КонецЦикла;
	
	// Физически пишем движения в базу ДО контроля остатков
	Движения.ОстаткиТоваров.Записать();
	
	// 3. Контроль отрицательных остатков
	Запрос = Новый Запрос;
	
	
	
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОстаткиТоваровОстатки.Номенклатура.Наименование КАК Деталь,
		|	ОстаткиТоваровОстатки.Серия.Наименование КАК Серийник,
		|	-ОстаткиТоваровОстатки.КоличествоОстаток КАК Нехватка
		|ИЗ
		|	РегистрНакопления.ОстаткиТоваров.Остатки(
		|		&ГраницаКонтроля,
		|		Склад = &Склад
		|			И (Номенклатура, Серия) В
		|				(ВЫБРАТЬ РАЗЛИЧНЫЕ
		|					Док.Номенклатура,
		|					Док.Серия
		|				ИЗ
		|					Документ.СписаниеТоваров.Товары КАК Док
		|				ГДЕ
		|					Док.Ссылка = &Ссылка)) КАК ОстаткиТоваровОстатки
		|ГДЕ
		|	ОстаткиТоваровОстатки.КоличествоОстаток < 0";
	
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	// Устанавливаем границу включая текущий документ, так как движения уже записаны
	ГраницаКонтроля = Новый Граница(МоментВремени(), ВидГраницы.Включая);
	Запрос.УстановитьПараметр("ГраницаКонтроля", ГраницаКонтроля);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	// 4. Если есть минуса — выводим ошибки и отменяем проведение
	Если Не РезультатЗапроса.Пустой() Тогда
		Отказ = Истина; // Отменяем транзакцию, движения откатятся платформой
		
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			
			ТекстОшибки = СтрШаблон(
				"Не хватает запчасти «%1» (серия: %2) в количестве %3 шт.", 
				Выборка.Деталь, 
				?(ЗначениеЗаполнено(Выборка.Серийник), Выборка.Серийник, "без серии"), 
				Выборка.Нехватка
			);
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = ТекстОшибки;
			Сообщение.КлючДанных = Ссылка; // Привязываем сообщение к текущему окну
			Сообщение.Сообщить();
			
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры
